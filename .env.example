# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Anthropic — Claude SDK authentication
ANTHROPIC_API_KEY=

# Emplicit Postgres — account config, report storage, and Intentwise-synced Amazon data
EMPLICIT_PG_HOST=
EMPLICIT_PG_PORT=5555
EMPLICIT_PG_DB=
EMPLICIT_PG_USER=
EMPLICIT_PG_PASSWORD=

# Slack — bot token for posting alerts and DMs
SLACK_BOT_TOKEN=
SLACK_OPS_CHANNEL=

# Teamwork — read-only task queries
TEAMWORK_DOMAIN=
TEAMWORK_API_TOKEN=

# Google — service account for creating Docs, saving to Drive, and reading Sheets
# Value is the raw JSON string of the service account key (paste contents of the JSON file on a single line)
# The service account needs: Google Docs, Google Drive, and Google Sheets API scopes + DWD configured in Google Admin
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google — Domain-Wide Delegation impersonation email
# Required for emplicit.co Google Workspace — set to a real Workspace user email (e.g. ops@emplicit.co)
# The service account will create Docs and Drive files on behalf of this user
GOOGLE_IMPERSONATION_EMAIL=

# Google Sheets — brand config and people lookup
BRAND_SHEET_ID=1r6fjq1PvPQLvipQlt0GxA-1RhmqVi1G9aCOA5-igmBg
PEOPLE_SHEET_ID=1DM45U40rwfjABWjavM590Jjfzfe4NoZwc0-ktmvVbkA

# Google Drive — folder ID where the daily ops summary Google Doc is saved
# Find the folder ID in the Drive URL: drive.google.com/drive/folders/<FOLDER_ID>
DRIVE_OPS_FOLDER_ID=
