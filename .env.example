# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Anthropic — Claude SDK authentication
ANTHROPIC_API_KEY=

# Emplicit Postgres — account config, report storage, and Intentwise-synced Amazon data
EMPLICIT_PG_HOST=
EMPLICIT_PG_PORT=5432
EMPLICIT_PG_DB=
EMPLICIT_PG_USER=
EMPLICIT_PG_PASSWORD=

# Slack — bot token for posting alerts and DMs
SLACK_BOT_TOKEN=
SLACK_OPS_CHANNEL=

# Teamwork — read-only task queries
TEAMWORK_DOMAIN=
TEAMWORK_API_TOKEN=

# Google — service account for creating Docs and saving to Drive
# Value should be the file path to the service account JSON (e.g. /secrets/sa.json)
# The service account needs: Google Docs API (documents scope) + Google Drive API (drive scope)
# april13 waiting on confirmation - confirm path format and whether to use file path or raw JSON
GOOGLE_SERVICE_ACCOUNT_JSON=
