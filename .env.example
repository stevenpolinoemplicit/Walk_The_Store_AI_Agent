# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Anthropic — Claude SDK authentication
ANTHROPIC_API_KEY=

# Emplicit Postgres — account config, report storage, and Intentwise-synced Amazon data
EMPLICIT_PG_HOST=
EMPLICIT_PG_PORT=5432
EMPLICIT_PG_DB=
EMPLICIT_PG_USER=
EMPLICIT_PG_PASSWORD=

# Slack — bot token for posting alerts and DMs
SLACK_BOT_TOKEN=
SLACK_OPS_CHANNEL=

# Teamwork — read-only task queries
TEAMWORK_DOMAIN=
TEAMWORK_API_TOKEN=

# Google — service account for creating Docs, saving to Drive, and reading Sheets
# Value is the file path to the service account JSON key file
# The service account needs: Google Docs, Google Drive, and Google Sheets API scopes
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheets — brand config and people lookup
BRAND_SHEET_ID=1r6fjq1PvPQLvipQlt0GxA-1RhmqVi1G9aCOA5-igmBg
PEOPLE_SHEET_ID=1DM45U40rwfjABWjavM590Jjfzfe4NoZwc0-ktmvVbkA
