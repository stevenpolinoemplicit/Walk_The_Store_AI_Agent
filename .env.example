# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Anthropic — Claude SDK authentication
ANTHROPIC_API_KEY=

# Intentwise MCP — Amazon account health data via OAuth
INTENTWISE_CLIENT_ID=
INTENTWISE_CLIENT_SECRET=
INTENTWISE_MCP_URL=https://mcp.intentwise.com/mcp

# Emplicit Postgres — account config and report storage
EMPLICIT_PG_HOST=
EMPLICIT_PG_PORT=5432
EMPLICIT_PG_DB=
EMPLICIT_PG_USER=
EMPLICIT_PG_PASSWORD=

# Slack — bot token for posting alerts and DMs
SLACK_BOT_TOKEN=
SLACK_OPS_CHANNEL=

# Teamwork — read-only task queries
TEAMWORK_DOMAIN=
TEAMWORK_API_TOKEN=
